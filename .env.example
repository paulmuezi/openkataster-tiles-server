# Public base URL used in generated TileJSON/API responses.
OPENKATASTER_TILE_PUBLIC_BASE_URL=https://tiles.openkataster.de

# Runtime data paths. These are mounted into the Docker container by docker-compose.yml.
OPENKATASTER_TILE_DATA_DIR=/srv/openkataster-tiles/data
OPENKATASTER_TILE_ACTIVE_VOLUME_ROOT=/srv/openkataster-tiles/active
OPENKATASTER_VIEWER_ROOT=/srv/openkataster-tiles/live-viewer
OPENKATASTER_LUFTBILD_CACHE_DIR=/srv/openkataster-tiles/cache/luftbild
OPENKATASTER_PMTILES_CACHE_DIR=/srv/openkataster-tiles/cache/pmtiles_range_cache
OPENKATASTER_TILE_MOSAIC_DISK_CACHE_DIR=/srv/openkataster-tiles/cache/mosaic
OPENKATASTER_TILE_RASTER_CACHE_DIR=/srv/openkataster-tiles/cache/raster
OPENKATASTER_GN250_PLACES_DB=/srv/openkataster-tiles/data/places.sqlite
OPENKATASTER_OPENPLZ_DB=/srv/openkataster-tiles/plz/openplz.sqlite
OPENKATASTER_POSTCODE_AREAS_DB=/srv/openkataster-tiles/plz/postcode_areas.sqlite
OPENKATASTER_GEOCODER_DB=/srv/openkataster-tiles/geocoder/geocoder.sqlite
OPENKATASTER_FAST_GEOCODER_DB=/srv/openkataster-tiles/geocoder/geocoder_fast.sqlite

# Dataset behavior.
OPENKATASTER_TILE_GERMANY_DATASET=deutschland
OPENKATASTER_TILE_SOURCE_MAX_ZOOM=17
OPENKATASTER_TILE_OVERVIEW_MAX_ZOOM=11
OPENKATASTER_TILE_WEB_MIN_ZOOM=4.0
OPENKATASTER_TILE_SEARCH_CACHE_SECONDS=120
OPENKATASTER_TILE_SEARCH_CACHE_MAX=512

# Cache sizing.
OPENKATASTER_PMTILES_CACHE_MAX_BYTES=42949672960
OPENKATASTER_PMTILES_CACHE_TARGET_BYTES=34359738368
OPENKATASTER_LUFTBILD_CACHE_MAX_BYTES=3221225472
OPENKATASTER_LUFTBILD_CACHE_TARGET_BYTES=2147483648

# Admin/API integration.
OPENKATASTER_ADMIN_API_BASE_URL=https://api.openkataster.de
OPENKATASTER_TILE_ADMIN_KEYS=change-me
OPENKATASTER_TILE_KEYS=change-me

# Viewer access tokens. Comma-separated static preview tokens until account-based auth exists.
OPENKATASTER_TILE_PRO_TOKENS=change-me

# Optional JWT/public-key based viewer auth.
OPENKATASTER_VIEWER_TOKEN_PUBLIC_KEY=
OPENKATASTER_VIEWER_TOKEN_AUDIENCE=lageplaner-api

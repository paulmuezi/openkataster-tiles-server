[Unit]
Description=OpenKataster Tiles API
After=network-online.target
Wants=network-online.target

[Service]
User=openkataster-tiles
Group=openkataster-tiles
WorkingDirectory=/opt/openkataster-tiles
EnvironmentFile=/etc/openkataster-tiles.env
ExecStart=/opt/openkataster-tiles/venv/bin/uvicorn openkataster_tiles.main:app --host 127.0.0.1 --port 8080 --workers 2
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
